{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Server",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "start"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "sso-demo"
      }
    },
    {
      "label": "Start React App",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/app-react"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "sso-demo"
      }
    },
    {
      "label": "Start Vue App",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/app-vue"
      },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "sso-demo"
      }
    },
    {
      "label": "Start All Services",
      "dependsOn": [
        "Start Server",
        "Start React App",
        "Start Vue App"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Start React and Vue Apps",
      "dependsOn": [
        "Start React App",
        "Start Vue App"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}